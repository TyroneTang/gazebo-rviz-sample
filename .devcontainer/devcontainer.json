{
  "name": "ROS 2 Humble + Gazebo Fortress",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "devcontainer",
  "runServices": [
      "devcontainer"
  ],
  "workspaceFolder": "/workspace/project",
  "remoteUser": "devuser",
  "containerUser": "devuser",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "smilerobotics.urdf",
        "DotJoshJohnson.xml",
        "Anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.associations": {
          "*.urdf": "xml",
          "*.xacro": "xml",
          "*.sdf": "xml",
          "*.world": "xml"
        }
      }
    }
  },
  "postCreateCommand": "sudo rosdep update --rosdistro=humble || true"
}
